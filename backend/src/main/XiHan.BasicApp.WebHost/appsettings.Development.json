{
  "XiHan": {
    "DistributedIds": {
      "SnowflakeId": {
        "WorkerId": 1,
        "DataCenterId": 1,
        "BaseTime": "2026-01-01",
        "SnowflakeIdType": "SnowflakeDriftMethod"
      }
    },
    "Authentication": {
      "PasswordHasher": {
        "Version": 1,
        "Iterations": 600000,
        "SaltSize": 32,
        "HashSize": 32,
        "HashAlgorithm": "SHA256"
      },
      "Jwt": {
        "SecretKey": "XiHanFrameworkJwtSecretKey2026SecurePasswordForDevelopment",
        "Issuer": "XiHan.BasicApp",
        "Audience": "XiHan.BasicApp.Client",
        "AccessTokenExpirationMinutes": 120,
        "RefreshTokenExpirationDays": 7,
        "ClockSkewMinutes": 5
      }
    },
    "Data": {
      "SqlSugarCore": {
        "ConnectionConfigs": [
          {
            "ConfigId": "1",
            "ConnectionString": "Server=127.0.0.1;Database=XiHanBasicApp;Username=postgres;Password=postgres;TrustServerCertificate=true;",
            "DbType": "PostgreSQL",
            "IsAutoCloseConnection": true,
            "SlaveConnectionConfigs": []
          }
          //{
          //  "ConfigId": "2",
          //  "ConnectionString": "Server=127.0.0.1;Database=XiHanBasicApp;User=root;Password=mysql;",
          //  "DbType": "MySQL",
          //  "IsAutoCloseConnection": true,
          //  "SlaveConnectionConfigs": []
          //},
          //{
          //  "ConfigId": "3",
          //  "ConnectionString": "Server=127.0.0.1;Database=XiHanBasicApp;User=root;Password=maria;",
          //  "DbType": "MySQL",
          //  "IsAutoCloseConnection": true,
          //  "SlaveConnectionConfigs": []
          //}
        ],
        "EnableSqlLog": false,
        "EnableSqlErrorLog": true,
        "EnableSlowSqlLog": true,
        "SlowSqlThresholdMilliseconds": 10000,
        "EnableDbInitialization": true,
        "EnableTableInitialization": true,
        "EnableDataSeeding": true,
        "GlobalFilters": {}
      }
    },
    "Upgrade": {
      "MinSupportVersion": "1.0.0",
      "AppVersion": "",
      "MigrationsRootPath": "migrations",
      "LockResourceKey": "SystemUpgrade",
      "LockExpirySeconds": 600,
      "EnableAutoCheckOnStartup": true,
      "NodeName": "",
      "PrimaryNodeName": "",
      "EnableMultiTenantIsolation": false,
      "ConnectionConfigId": "1",
      "EnableMaintenanceMode": true,
      "EnableFileUpdate": false,
      "EnableRollingRestart": false
    }
  },
  "Caching": {
    "Redis": {
      "IsEnabled": true,
      "Configuration": "127.0.0.1:6379,password=mypassword,defaultDatabase=0",
      "InstanceName": "XiHan:",
      "ConnectTimeout": 5000,
      "SyncTimeout": 5000,
      "AsyncTimeout": 5000,
      "AllowAdmin": false,
      "UseSsl": false,
      "AbortOnConnectFail": false
    }
  },
  "SignalR": {
    // 是否启用详细错误信息（生产环境建议设置为 false）
    "EnableDetailedErrors": false,
    // 保持连接间隔时间（格式：hh:mm:ss）
    "KeepAliveInterval": "00:00:15",
    // 客户端超时时间
    "ClientTimeoutInterval": "00:00:30",
    // 握手超时时间
    "HandshakeTimeout": "00:00:15",
    // 最大接收消息大小（字节）32KB
    "MaximumReceiveMessageSize": 32768,
    // 流缓冲容量
    "StreamBufferCapacity": 10,
    // 每个客户端的最大并行调用数
    "MaximumParallelInvocationsPerClient": 1,
    // 是否启用连接指标
    "EnableConnectionMetrics": true
  },
  "Gateway": {
    "EnableGrayRouting": true,
    "EnableRequestTracing": true,
    "EnableRateLimiting": false,
    "EnableCircuitBreaker": false,
    "RequestTimeoutSeconds": 30,
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://example.com"
    ],
    "GlobalHeaders": {
      "X-Powered-By": "XiHan Framework",
      "X-Gateway-Version": "1.0"
    }
  },
  "GrayRouting": {
    "Rules": [
      {
        "RuleId": "rule-percentage-10",
        "RuleName": "10% 流量灰度",
        "RuleType": 1,
        "IsEnabled": true,
        "Priority": 100,
        "TargetVersion": "v2",
        "Configuration": "{\"percentage\":10}",
        "Remark": "10% 的流量路由到新版本"
      },
      {
        "RuleId": "rule-user-whitelist",
        "RuleName": "用户白名单灰度",
        "RuleType": 2,
        "IsEnabled": true,
        "Priority": 10,
        "TargetVersion": "v2",
        "Configuration": "{\"userIds\":[\"user1\",\"user2\",\"user3\"]}",
        "Remark": "指定用户访问新版本"
      },
      {
        "RuleId": "rule-tenant-beta",
        "RuleName": "Beta 租户灰度",
        "RuleType": 3,
        "IsEnabled": true,
        "Priority": 20,
        "TargetVersion": "v2",
        "Configuration": "{\"tenantIds\":[\"00000000-0000-0000-0000-000000000001\"]}",
        "Remark": "Beta 租户访问新版本"
      },
      {
        "RuleId": "rule-header-gray",
        "RuleName": "Header 灰度",
        "RuleType": 4,
        "IsEnabled": true,
        "Priority": 5,
        "TargetVersion": "v2",
        "Configuration": "{\"headerName\":\"X-Gray\",\"headerValue\":\"true\"}",
        "Remark": "带有 X-Gray: true Header 的请求路由到新版本"
      }
    ]
  }
}