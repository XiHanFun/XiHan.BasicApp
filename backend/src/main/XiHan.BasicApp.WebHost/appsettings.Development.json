{
  // 应用宿主（Kestrel）监听设置
  "Hosting": {
    // 监听地址与端口；多个用分号分隔，如 "http://0.0.0.0:9708;https://0.0.0.0:9709"
    "Urls": "http://127.0.0.1:9708"
  },
  "XiHan": {
    // 演示模式：开启后拦截一切写操作（增删改），仅供只读演示
    "Demo": {
      // 是否启用演示模式（本地开发默认关闭）
      "Enabled": false,
      // 命中写操作拦截时返回给前端的提示语
      "Message": "演示环境禁止修改数据，仅供查看",
      // 演示模式下仍放行的接口白名单（登录、刷新令牌、改密等必须可用）
      "AllowedPaths": [
        "/api/Auth/Login",
        "/api/Auth/RefreshToken",
        "/api/Auth/Logout",
        "/api/Auth/ExternalLogin",
        "/api/Auth/ExternalLoginCallback",
        "/api/Auth/SendVerificationCode",
        "/api/Auth/VerifyCode",
        "/api/Auth/ResetPassword",
        "/api/Profile"
      ]
    },
    // 分布式 ID 生成器（雪花算法）
    "DistributedIds": {
      "SnowflakeId": {
        // 工作机器 ID：同一集群内每个节点必须唯一，否则会生成重复 ID
        "WorkerId": 1,
        // 数据中心 ID：多机房时区分，单机房固定即可
        "DataCenterId": 1,
        // 起始纪元时间：一经上线不可更改（改动会导致 ID 回退甚至冲突）
        "BaseTime": "2026-01-01",
        // 算法类型：SnowflakeDriftMethod=漂移算法（抗时钟回拨、吞吐更高）
        "SnowflakeIdType": "SnowflakeDriftMethod"
      }
    },
    // 认证与授权
    "Authentication": {
      // 密码哈希（PBKDF2）参数
      "PasswordHasher": {
        // 哈希方案版本号：用于将来平滑升级算法/参数（老密码按旧版本校验）
        "Version": 1,
        // 迭代次数：越大越安全但越慢，60 万为 OWASP 对 PBKDF2-SHA256 的推荐量级
        "Iterations": 600000,
        // 盐长度（字节）
        "SaltSize": 32,
        // 哈希输出长度（字节）
        "HashSize": 32,
        // 哈希算法
        "HashAlgorithm": "SHA256"
      },
      // JWT 令牌配置
      "Jwt": {
        // 签名密钥：⚠ 生产环境务必改为高强度随机值并保密（勿提交明文，建议走环境变量/密钥管理）
        "SecretKey": "XiHanFrameworkJwtSecretKey2026SecurePasswordForDevelopment",
        // 签发者（iss），校验令牌来源
        "Issuer": "XiHan.BasicApp",
        // 受众（aud），校验令牌使用方
        "Audience": "XiHan.BasicApp.Client",
        // 访问令牌有效期（分钟）
        "AccessTokenExpirationMinutes": 120,
        // 刷新令牌有效期（天）
        "RefreshTokenExpirationDays": 7,
        // 允许的时钟偏差（分钟），容忍多节点间时间误差
        "ClockSkewMinutes": 5
      },
      // 第三方 OAuth 登录
      "OAuth": {
        // OAuth 总开关
        "Enabled": true,
        // 第三方登录成功后跳回的前端回调页
        "FrontendCallbackUrl": "http://localhost:9800/#/auth/oauth-callback",
        // 各提供商配置（本地为占位值，需到对应平台申请后替换 ClientId/ClientSecret）
        "Providers": [
          {
            // Name：内部标识，用于回调路由与识别，勿随意改
            "Name": "github",
            // DisplayName：前端展示名
            "DisplayName": "GitHub",
            "Enabled": true,
            "ClientId": "your-github-client-id",
            "ClientSecret": "your-github-client-secret",
            // Scopes：申请的授权范围
            "Scopes": [ "read:user", "user:email" ]
          },
          {
            "Name": "google",
            "DisplayName": "Google",
            "Enabled": true,
            "ClientId": "your-google-client-id",
            "ClientSecret": "your-google-client-secret",
            "Scopes": []
          },
          {
            "Name": "qq",
            "DisplayName": "QQ",
            "Enabled": true,
            "ClientId": "your-qq-app-id",
            "ClientSecret": "your-qq-app-key",
            "Scopes": []
          }
        ]
      }
    },
    // 数据访问（SqlSugar ORM）
    "Data": {
      "SqlSugarCore": {
        // 数据库连接集合：可配多库，靠 ConfigId 区分（多租户/多数据源按需扩展）
        "ConnectionConfigs": [
          {
            // ConfigId：连接唯一标识（多库/多租户路由用），字符串
            "ConfigId": "1",
            // 主库连接字符串
            "ConnectionString": "Server=127.0.0.1;Database=XiHanBasicApp;Username=postgres;Password=postgres;TrustServerCertificate=true;",
            // 数据库类型：PostgreSQL / MySql / SqlServer 等（取 SqlSugar 的 DbType 枚举）
            "DbType": "PostgreSQL",
            // 是否自动关闭连接（true 更省心，无需手动 close）
            "IsAutoCloseConnection": true,
            // 从库连接（读写分离）；为空数组表示单库、不分离
            "SlaveConnectionConfigs": []
          }
          // 主从读写分离示例：填了从库后 SELECT 自动走从库、写与事务走主库，业务无感知。
          // 注意 HitRate(读权重) 是 SqlSugar 的字段、绑不上 appsettings，这里写了也无效、恒为 0；
          // 框架会把权重为 0 的从库归一化为 DefaultSlaveHitRate(默认 10)，所以下面无需写 HitRate 也能等权分担读。
          // 需要差异化权重/挂 ConfigureExternalServices/自写探活，请用代码钩子 XiHanSqlSugarCoreOptions.ConfigureConnectionConfigs。
          //{
          //  "ConfigId": "2",
          //  "ConnectionString": "Server=主库;Database=XiHanBasicApp;Username=postgres;Password=postgres;TrustServerCertificate=true;",
          //  "DbType": "PostgreSQL",
          //  "IsAutoCloseConnection": true,
          //  "DbLinkName": null,      // 原生字段：跨库 DbLink 名，可选
          //  "LanguageType": null,    // 原生字段：SqlSugar 报错信息语言，可选
          //  "IndexSuffix": null,     // 原生字段：索引后缀，可选
          //  "SlaveConnectionConfigs": [
          //    { "ConnectionString": "Server=从库1;Database=XiHanBasicApp;Username=postgres;Password=postgres;TrustServerCertificate=true;" },
          //    { "ConnectionString": "Server=从库2;Database=XiHanBasicApp;Username=postgres;Password=postgres;TrustServerCertificate=true;" }
          //  ]
          //}
        ],
        // 是否打印所有 SQL（调试用，生产建议关闭以免日志爆量）
        "EnableSqlLog": false,
        // 是否记录 SQL 异常日志
        "EnableSqlErrorLog": true,
        // 是否记录慢 SQL 日志
        "EnableSlowSqlLog": true,
        // 慢 SQL 阈值（毫秒）；同时决定命令超时时间（该值 ÷ 1000 秒）
        "SlowSqlThresholdMilliseconds": 10000,
        // 启动时自动建库（库不存在则创建）
        "EnableDbInitialization": true,
        // 启动时 CodeFirst 建表/同步表结构
        "EnableTableInitialization": true,
        // 启动时写入种子数据
        "EnableDataSeeding": true,
        // 全局查询过滤器（一般由代码注册，此处留空）
        "GlobalFilters": {},
        // 从库相关（可选）：DefaultSlaveHitRate=appsettings 从库权重归一化默认值；
        // 打开 EnableSlaveHealthCheck 后后台周期探活，不可用从库自动摘除读权重、恢复按冷却窗口回填。
        "DefaultSlaveHitRate": 10,
        // 是否启用从库健康探针（默认关，仅在配了从库时才有意义）
        "EnableSlaveHealthCheck": false,
        // 探测周期（秒）
        "SlaveHealthCheckIntervalSeconds": 30,
        // 故障冷却窗口（秒）：从库恢复后先冷却再回填权重，避免抖动
        "SlaveFailureCooldownSeconds": 120
      }
    },
    // 系统升级/迁移（多节点协调 + 分布式锁）
    "Upgrade": {
      // 允许升级的最低来源版本
      "MinSupportVersion": "1.0.0",
      // 当前应用版本（留空则运行时探测程序集版本）
      "AppVersion": "",
      // 迁移脚本根目录
      "MigrationsRootPath": "migrations",
      // 分布式锁资源名（防多节点并发执行升级）
      "LockResourceKey": "SystemUpgrade",
      // 分布式锁过期时间（秒）
      "LockExpirySeconds": 600,
      // 启动时自动检查是否需要升级
      "EnableAutoCheckOnStartup": true,
      // 当前节点名（多节点部署时区分）
      "NodeName": "",
      // 主节点名（仅主节点执行迁移，其余等待）
      "PrimaryNodeName": "",
      // 升级是否按多租户逐库隔离执行
      "EnableMultiTenantIsolation": false,
      // 升级使用的数据库连接 ConfigId（对应上面的 ConnectionConfigs）
      "ConnectionConfigId": "1",
      // 升级期间是否进入维护模式（对外返回维护提示）
      "EnableMaintenanceMode": true,
      // 是否执行文件更新
      "EnableFileUpdate": false,
      // 是否滚动重启
      "EnableRollingRestart": false
    },
    // 缓存（Redis）
    "Caching": {
      "Redis": {
        // 是否启用 Redis（关闭则退化为内存缓存）
        "IsEnabled": true,
        // 连接串：host:port,user=,password=,defaultDatabase=
        "Configuration": "127.0.0.1:6379,user=redis,password=redis,defaultDatabase=0",
        // 缓存 Key 统一前缀（隔离不同应用/环境）
        "InstanceName": "XiHan:",
        // 连接超时（毫秒）
        "ConnectTimeout": 5000,
        // 同步操作超时（毫秒）
        "SyncTimeout": 5000,
        // 异步操作超时（毫秒）
        "AsyncTimeout": 5000,
        // 是否允许管理类命令（FLUSHDB/CONFIG 等，危险，生产慎开）
        "AllowAdmin": false,
        // 是否使用 SSL
        "UseSsl": false,
        // 连接失败是否立即中止（false=后台持续重连，更适合生产）
        "AbortOnConnectFail": false
      }
    },
    // Web 层
    "Web": {
      "Core": {
        // 客户端信息采集
        "ClientInfo": {
          // 是否启用 IP 归属地解析
          "EnableIpRegion": true,
          // ip2region 离线库路径
          "Ip2RegionDbPath": "IpDatabases/ip2region.xdb"
        }
      },
      "Api": {
        "Auth": {
          // 是否全局要求已认证用户（匿名接口需显式放行）
          "RequireAuthenticatedUser": true,
          // SignalR Hub 路由前缀
          "SignalRHubPathPrefix": "/hubs"
        },
        // 跨域（CORS）
        "Cors": {
          // 允许的来源（携带凭证时不能用 * 通配，必须显式列出）
          "AllowedOrigins": [ "http://localhost:9999", "http://127.0.0.1:9999" ],
          // 是否允许任意来源（与 AllowCredentials 互斥）
          "AllowAnyOrigin": false,
          // 是否允许任意方法
          "AllowAnyMethod": true,
          // 是否允许任意请求头
          "AllowAnyHeader": true,
          // 是否允许携带凭证（Cookie/Authorization）
          "AllowCredentials": true,
          // 额外暴露给前端 JS 读取的响应头
          "ExposedHeaders": [],
          // 预检请求（OPTIONS）结果缓存秒数
          "PreflightMaxAgeSeconds": 0
        },
        // 开放接口安全（请求签名 / 防重放 / 加密）
        "OpenApiSecurity": {
          // 总开关（关闭则不做签名/加密校验）
          "IsEnabled": false,
          // 是否允许未签名请求通过
          "AllowUnsignedRequests": true,
          // 是否要求请求体内容签名
          "RequireContentSignature": true,
          // 是否启用防重放保护
          "EnableReplayProtection": true,
          // 时间戳容差（秒），超出视为过期请求
          "TimestampToleranceSeconds": 300,
          // Nonce（一次性随机数）有效期（秒）
          "NonceExpireSeconds": 300,
          // 最大请求体大小（字节）2MB
          "MaxRequestBodySize": 2097152,
          // 是否启用响应加密
          "EnableResponseEncryption": true,
          // 请求加密时是否默认对响应也加密
          "EncryptResponseByDefaultWhenRequestEncrypted": true,
          // 默认请求签名算法
          "DefaultSignatureAlgorithm": "HMACSHA256",
          // 默认内容签名算法
          "DefaultContentSignatureAlgorithm": "SHA256",
          // 默认加密算法
          "DefaultEncryptionAlgorithm": "AES-CBC",
          // 需要保护（校验签名/加密）的路径前缀
          "ProtectedPathPrefixes": [ "/api" ],
          // 忽略校验的路径前缀（文档/健康检查等）
          "IgnoredPathPrefixes": [ "/scalar", "/swagger", "/health", "/openapi" ],
          // 已授权客户端密钥列表
          "Clients": [
            {
              // 客户端标识
              "AccessKey": "basicapp-frontend",
              // 签名密钥（⚠ 敏感，生产需替换保密）
              "SecretKey": "basicapp_frontend_signature_secret_2026",
              // 加密密钥（⚠ 敏感）
              "EncryptKey": "basicapp_frontend_encrypt_secret_2026",
              "SignatureAlgorithm": "HMACSHA256",
              "ContentSignatureAlgorithm": "SHA256",
              "EncryptionAlgorithm": "AES-CBC",
              // 是否允许对该客户端的响应加密
              "AllowResponseEncryption": true,
              // IP 白名单（空=不限制）
              "IpWhitelist": [ "127.0.0.1", "::1" ],
              "IsEnabled": true
            }
          ]
        }
      },
      // 实时通信（SignalR）
      "RealTime": {
        "SignalR": {
          // 是否启用详细错误信息（生产环境建议设置为 false）
          "EnableDetailedErrors": false,
          // 保持连接间隔时间（格式：hh:mm:ss）
          "KeepAliveInterval": "00:00:15",
          // 客户端超时时间
          "ClientTimeoutInterval": "00:00:30",
          // 握手超时时间
          "HandshakeTimeout": "00:00:15",
          // 最大接收消息大小（字节）32KB
          "MaximumReceiveMessageSize": 32768,
          // 流缓冲容量
          "StreamBufferCapacity": 10,
          // 每个客户端的最大并行调用数
          "MaximumParallelInvocationsPerClient": 1,
          // 是否启用连接指标
          "EnableConnectionMetrics": true
        }
      },
      // 网关
      "Gateway": {
        // 启用灰度路由
        "EnableGrayRouting": true,
        // 启用请求链路追踪
        "EnableRequestTracing": true,
        // 启用限流
        "EnableRateLimiting": false,
        // 启用熔断
        "EnableCircuitBreaker": false,
        // 网关请求超时（秒）
        "RequestTimeoutSeconds": 30,
        // 允许来源
        "AllowedOrigins": [ "http://localhost:3000", "https://example.com" ],
        // 网关统一注入的响应头
        "GlobalHeaders": {
          "X-Powered-By": "XiHan Framework",
          "X-Gateway-Version": "1.0"
        }
      },
      // 灰度路由规则
      "GrayRouting": {
        // RuleType：1=按百分比 2=用户白名单 3=租户 4=请求头；Priority 越大越优先
        "Rules": [
          {
            "RuleId": "rule-percentage-10",
            "RuleName": "10% 流量灰度",
            "RuleType": 1,
            "IsEnabled": true,
            "Priority": 100,
            "TargetVersion": "v2",
            // 规则参数（JSON 字符串）：10% 流量
            "Configuration": "{\"percentage\":10}",
            "Remark": "10% 的流量路由到新版本"
          },
          {
            "RuleId": "rule-user-whitelist",
            "RuleName": "用户白名单灰度",
            "RuleType": 2,
            "IsEnabled": true,
            "Priority": 10,
            "TargetVersion": "v2",
            "Configuration": "{\"userIds\":[\"user1\",\"user2\",\"user3\"]}",
            "Remark": "指定用户访问新版本"
          },
          {
            "RuleId": "rule-tenant-beta",
            "RuleName": "Beta 租户灰度",
            "RuleType": 3,
            "IsEnabled": true,
            "Priority": 20,
            "TargetVersion": "v2",
            "Configuration": "{\"tenantIds\":[\"00000000-0000-0000-0000-000000000001\"]}",
            "Remark": "Beta 租户访问新版本"
          },
          {
            "RuleId": "rule-header-gray",
            "RuleName": "Header 灰度",
            "RuleType": 4,
            "IsEnabled": true,
            "Priority": 5,
            "TargetVersion": "v2",
            "Configuration": "{\"headerName\":\"X-Gray\",\"headerValue\":\"true\"}",
            "Remark": "带有 X-Gray: true Header 的请求路由到新版本"
          }
        ]
      }
    },
    // 本地化（多语言）
    "Localization": {
      // 资源文件目录
      "ResourcesPath": "/Localization",
      // 默认资源名
      "DefaultResourceName": "Default",
      // 默认文化（zh-CN 简体中文）
      "DefaultCulture": "zh-CN",
      // 枚举文案资源名（枚举标签的单一事实源）
      "EnumResourceName": "Enums",
      // 是否启用资源 JSON 动态热重载
      "EnableDynamicJsonReload": true
    },
    // 虚拟文件系统（嵌入资源 + 物理目录）
    "VirtualFileSystem": {
      // 包含当前工作目录
      "IncludeCurrentDirectory": true,
      // 包含应用程序基目录
      "IncludeAppBaseDirectory": true
    },
    // 对象存储
    "ObjectStorage": {
      // 本地磁盘存储
      "Local": {
        // 文件落盘根目录
        "RootPath": "wwwroot/uploads",
        // 对外访问 URL 前缀（本地存储返回根相对路径，跨源时前端拼 API origin）
        "UrlPrefix": "/uploads"
      }
    }
  }
}