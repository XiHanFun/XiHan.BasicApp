<Project Sdk="Microsoft.NET.Sdk.Web">

    <Import Project="..\..\..\props\netcore.props" />
    <Import Project="..\..\..\props\common.props" />
    <Import Project="..\..\..\props\version.props" />

    <PropertyGroup>
        <Title>XiHan.BasicApp.WebHost</Title>
        <AssemblyName>XiHan.BasicApp.WebHost</AssemblyName>
        <PackageId>XiHan.BasicApp.WebHost</PackageId>
        <Description>曦寒基础应用 Web 主机</Description>
		<IsPackable>false</IsPackable>
		<GenerateDocumentationFile>false</GenerateDocumentationFile>
		<OutputType>Exe</OutputType>
    </PropertyGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\modules\XiHan.BasicApp.AI\XiHan.BasicApp.AI.Local.csproj" />
      <ProjectReference Include="..\..\modules\XiHan.BasicApp.CodeGeneration\XiHan.BasicApp.CodeGeneration.Local.csproj" />
      <ProjectReference Include="..\..\modules\XiHan.BasicApp.Saas\XiHan.BasicApp.Saas.Local.csproj" />
    </ItemGroup>

    <ItemGroup>
      <!-- MCP Server 的 HTTP 传输 + MapMcp（WithHttpTransport/MapMcp 仅此包提供；与 ModelContextProtocol 同版本 1.4.0） -->
      <PackageReference Include="ModelContextProtocol.AspNetCore" Version="1.4.0" />
    </ItemGroup>

    <ItemGroup>
      <None Update="IpDatabases\ip2region.xdb">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
      <None Update="Localization\**\*.json">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </None>
    </ItemGroup>

    <ItemGroup>
      <Folder Include="wwwroot\" />
    </ItemGroup>

</Project>
