{
  "Hosting": {
    "Urls": "http://127.0.0.1:5000"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "XiHan": {
    "Localization": {
      "ResourcesPath": "/Localization",
      "DefaultResourceName": "Default",
      "DefaultCulture": "zh-CN",
      "EnumResourceName": "Enums",
      "EnableDynamicJsonReload": true
    },
    "VirtualFileSystem": {
      "IncludeCurrentDirectory": true,
      "IncludeAppBaseDirectory": true
    },
    "Email": {
      "Enabled": false,
      "SmtpHost": "",
      "SmtpPort": 587,
      "UseSsl": true,
      "FromEmail": "noreply@xihanfun.com",
      "FromName": "XiHan BasicApp",
      "UserName": "",
      "Password": ""
    }
  },
  "AllowedHosts": "*"
}