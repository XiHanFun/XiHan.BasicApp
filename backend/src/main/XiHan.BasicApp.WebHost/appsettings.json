{
  "Hosting": {
    "Urls": "http://127.0.0.1:5000"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CodeGeneration": {
    "EnableCustomPathDisk": false,
    "AllowedRootPaths": []
  },
  "AllowedHosts": "*",
  "XiHan": {
    "Web": {
      "Api": {
        "OpenApiSecurity": {
          "IsEnabled": false,
          "AllowUnsignedRequests": true,
          "RequireContentSignature": true,
          "EnableReplayProtection": true,
          "TimestampToleranceSeconds": 300,
          "NonceExpireSeconds": 300,
          "DefaultSignatureAlgorithm": "HMACSHA256",
          "ProtectedPathPrefixes": [ "/api/openapi" ],
          "IgnoredPathPrefixes": [ "/openapi", "/swagger", "/health", "/connect" ]
        }
      }
    }
  }
}