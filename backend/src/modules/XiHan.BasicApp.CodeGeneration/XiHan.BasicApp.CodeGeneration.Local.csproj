<Project Sdk="Microsoft.NET.Sdk">

    <Import Project="..\..\..\props\netcore.props" />
    <Import Project="..\..\..\props\common.props" />
    <Import Project="..\..\..\props\version.props" />
    <Import Project="..\..\..\props\nuget.props" />

    <PropertyGroup>
        <Title>XiHan.BasicApp.CodeGeneration</Title>
        <AssemblyName>XiHan.BasicApp.CodeGeneration</AssemblyName>
        <PackageId>XiHan.BasicApp.CodeGeneration</PackageId>
        <Description>曦寒基础应用代码生成库</Description>
        <OutputType>Library</OutputType>
    </PropertyGroup>

    <ItemGroup>
      <ProjectReference Include="..\XiHan.BasicApp.Saas\XiHan.BasicApp.Saas.Local.csproj" />
    </ItemGroup>

    <ItemGroup>
      <!-- 代码生成直接用原生 Scriban 渲染（框架 string 默认引擎不解析 Scriban 语法）；版本对齐框架 Templating -->
      <PackageReference Include="Scriban" Version="7.2.5" />
    </ItemGroup>

    <ItemGroup>
      <EmbeddedResource Include="Templates\**\*.sbn" />
    </ItemGroup>

</Project>