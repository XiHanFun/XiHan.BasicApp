    </PropertyGroup>

    <ItemGroup>
      <ProjectReference Include="..\XiHan.BasicApp.Saas\XiHan.BasicApp.Saas.Local.csproj" />
    </ItemGroup>

    <ItemGroup>
      <!-- Qdrant 向量库连接器（RAG）；实现 Microsoft.Extensions.VectorData 抽象，当前仅 preview，钉版本确保可复现 -->
