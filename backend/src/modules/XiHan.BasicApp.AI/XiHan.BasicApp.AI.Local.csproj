<Project Sdk="Microsoft.NET.Sdk">

    <Import Project="..\..\..\props\netcore.props" />
    <Import Project="..\..\..\props\common.props" />
    <Import Project="..\..\..\props\version.props" />
    <Import Project="..\..\..\props\nuget.props" />

    <PropertyGroup>
        <Title>XiHan.BasicApp.AI</Title>
        <AssemblyName>XiHan.BasicApp.AI</AssemblyName>
        <PackageId>XiHan.BasicApp.AI</PackageId>
        <Description>曦寒基础应用 AI 库</Description>
