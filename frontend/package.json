{
  "name": "XiHanBasicApp",
  "type": "module",
  "version": "3.0.0",
  "lastBuildTime": "2026.06.20",
  "packageManager": "pnpm@11.7.0",
  "description": "XiHan BasicApp - A modern Vue3 admin management system built on Naive UI",
  "keyword": [
    "Vue",
    "Vue3",
    "Naive UI",
    "Pinia",
    "Vite",
    "Tailwind CSS",
    "TypeScript",
    "BasicApp",
    "XiHan"
  ],
  "author": {
    "name": "ZhaiFanhua",
    "email": "zhaifanhua@foxmail.com",
    "url": "https://www.zhaifanhua.com"
  },
  "license": "MIT",
  "homepage": "https://basicapp.xihanfun.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/XiHanFun/XiHan.BasicApp"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "dev": "vite --mode development",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "cross-env CI=true oxlint && cross-env CI=true eslint .",
    "lint:fix": "cross-env CI=true oxlint --fix && cross-env CI=true eslint . --fix",
    "format": "prettier --write \"**/*.{json,css,html,md}\" --ignore-path .gitignore",
    "fix": "cross-env CI=true oxlint --fix && cross-env CI=true eslint . --fix && prettier --write \"**/*.{json,css,html,md}\" --ignore-path .gitignore",
    "postinstall": "simple-git-hooks",
    "clean": "rimraf dist",
    "clean:modules": "rimraf node_modules",
    "upgrade": "pnpm upgrade",
    "build": "vue-tsc --noEmit && vite build --mode production",
    "build:dev": "vite build --mode development",
    "reinstall": "pnpm run clean:modules && pnpm install",
    "rebuild": "pnpm run clean && pnpm run build",
    "rebuild:dev": "pnpm run clean && pnpm run build:dev"
  },
  "dependencies": {
    "@dnd-kit/geometry": "^0.5.0",
    "@dnd-kit/vue": "^0.5.0",
    "@iconify/vue": "^5.0.1",
    "@microsoft/signalr": "^10.0.0",
    "@tiptap/extension-color": "^3.27.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/vue-3": "^3.27.1",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "defu": "^6.1.7",
    "highlight.js": "^11.11.1",
    "md-editor-v3": "^6.5.3",
    "naive-ui": "^2.44.1",
    "papaparse": "^5.5.4",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pinyin-pro": "^3.28.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "vue3-ts-jsoneditor": "^3.4.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@iconify-json/carbon": "^1.2.23",
    "@iconify-json/ep": "^1.2.4",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/tabler": "^1.2.35",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.4",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.71.0",
    "prettier": "^3.8.4",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.0",
    "vue-tsc": "^3.3.5"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs}": [
      "oxlint --fix",
      "eslint --fix"
    ],
    "*.{json,css,html,md,yaml}": [
      "prettier --write"
    ]
  }
}
