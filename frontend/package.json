{
  "name": "XiHanBasicApp",
  "type": "module",
  "version": "3.6.0",
  "lastBuildTime": "2026.07.15",
  "packageManager": "pnpm@11.7.0",
  "description": "XiHan BasicApp - A modern Vue3 admin management system built on Naive UI",
  "keyword": [
    "Vue",
    "Vue3",
    "Naive UI",
    "Pinia",
    "Vite",
    "Tailwind CSS",
    "TypeScript",
    "BasicApp",
    "XiHan"
  ],
  "author": {
    "name": "ZhaiFanhua",
    "email": "zhaifanhua@foxmail.com",
    "url": "https://www.zhaifanhua.com"
  },
  "license": "MIT",
  "homepage": "https://basicapp.xihanfun.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/XiHanFun/XiHan.BasicApp"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite --mode development",
    "build": "pnpm run type-check && vite build --mode production",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "cross-env CI=true oxlint && cross-env CI=true eslint .",
    "lint:fix": "cross-env CI=true oxlint --fix && cross-env CI=true eslint . --fix",
    "format": "prettier --write \"**/*.{json,css,html,md}\" --ignore-path .gitignore",
    "fix": "pnpm run lint:fix && pnpm run format",
    "check": "pnpm run type-check && pnpm run lint",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "clean:modules": "node -e \"require('node:fs').rmSync('node_modules',{recursive:true,force:true,maxRetries:5,retryDelay:200})\"",
    "reinstall": "pnpm run clean:modules && pnpm install",
    "rebuild": "pnpm run clean && pnpm run build",
    "rebuild:dev": "pnpm run clean && pnpm run build:dev",
    "deps:check": "pnpm outdated",
    "deps:update": "pnpm update --latest -i",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@vueuse/core": "catalog:",
    "naive-ui": "catalog:",
    "pinia": "catalog:",
    "vue": "catalog:",
    "vue-i18n": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "cross-env": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "lint-staged": "catalog:",
    "oxlint": "catalog:",
    "prettier": "catalog:",
    "simple-git-hooks": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "unplugin-auto-import": "catalog:",
    "unplugin-vue-components": "catalog:",
    "vite": "catalog:",
    "vue-tsc": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs}": [
      "oxlint --fix",
      "eslint --fix"
    ],
    "*.{json,css,html,md,yaml}": [
      "prettier --write"
    ]
  }
}
