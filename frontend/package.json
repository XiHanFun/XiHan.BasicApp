{
  "name": "xihan-basic-app",
  "type": "module",
  "version": "1.3.0",
  "lastBuildTime": "2026.05.05",
  "packageManager": "pnpm@10.4.0",
  "description": "XiHan BasicApp - A modern Vue3 admin management system built on Naive UI",
  "keyword": [
    "Vue",
    "Vue3",
    "Naive UI",
    "Pinia",
    "Vite",
    "Tailwind CSS",
    "TypeScript",
    "BasicApp",
    "XiHan"
  ],
  "author": {
    "name": "ZhaiFanhua",
    "email": "zhaifanhua@foxmail.com",
    "url": "https://www.zhaifanhua.com"
  },
  "license": "MIT",
  "homepage": "https://basicapp.xihanfun.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/XiHanFun/XiHan.BasicApp"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "dev": "vite --mode development",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "cross-env CI=true oxlint && cross-env CI=true eslint .",
    "lint:fix": "cross-env CI=true oxlint --fix && cross-env CI=true eslint . --fix",
    "format": "prettier --write \"**/*.{json,css,html,md}\" --ignore-path .gitignore",
    "fix": "cross-env CI=true oxlint --fix && cross-env CI=true eslint . --fix && prettier --write \"**/*.{json,css,html,md}\" --ignore-path .gitignore",
    "postinstall": "simple-git-hooks",
    "clean": "rimraf dist",
    "clean:modules": "rimraf node_modules",
    "upgrade": "pnpm upgrade",
    "build": "vue-tsc --noEmit && vite build --mode production",
    "build:dev": "vite build --mode development",
    "reinstall": "pnpm run clean:modules && pnpm install",
    "rebuild": "pnpm run clean && pnpm run build",
    "rebuild:dev": "pnpm run clean && pnpm run build:dev"
  },
  "dependencies": {
    "@dnd-kit/geometry": "^0.4.0",
    "@dnd-kit/vue": "^0.4.0",
    "@iconify/vue": "^4.3.0",
    "@microsoft/signalr": "^10.0.0",
    "@tiptap/extension-color": "^3.26.0",
    "@tiptap/extension-highlight": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/extension-text-align": "^3.26.0",
    "@tiptap/extension-text-style": "^3.26.0",
    "@tiptap/extension-underline": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@tiptap/vue-3": "^3.26.0",
    "@vue-office/docx": "^1.6.3",
    "@vue-office/excel": "^1.7.14",
    "@vue-office/pptx": "^1.0.1",
    "@vueuse/core": "^11.3.0",
    "axios": "^1.17.0",
    "dayjs": "^1.11.21",
    "defu": "^6.1.7",
    "highlight.js": "^11.11.1",
    "md-editor-v3": "^6.5.1",
    "naive-ui": "^2.44.1",
    "papaparse": "^5.5.3",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^3.2.3",
    "vue": "^3.5.35",
    "vue-demi": "^0.14.10",
    "vue-i18n": "^11.4.5",
    "vue-router": "^4.6.4",
    "vue3-ts-jsoneditor": "^3.4.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@iconify-json/carbon": "^1.2.23",
    "@iconify-json/ep": "^1.2.4",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.111",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/tabler": "^1.2.35",
    "@types/node": "^25.9.2",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^1.5.0",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^0.18.6",
    "unplugin-vue-components": "^0.28.0",
    "vite": "^6.4.3",
    "vue-tsc": "^2.2.12"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs}": [
      "oxlint --fix",
      "eslint --fix"
    ],
    "*.{json,css,html,md,yaml}": [
      "prettier --write"
    ]
  }
}
