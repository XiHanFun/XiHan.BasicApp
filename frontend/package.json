{
  "name": "XiHanBasicApp",
  "type": "module",
  "version": "3.6.0",
  "lastBuildTime": "2026.07.15",
  "packageManager": "pnpm@11.7.0",
  "description": "XiHan BasicApp - A modern Vue3 admin management system built on Naive UI",
  "keyword": [
    "Vue",
    "Vue3",
    "Naive UI",
    "Pinia",
    "Vite",
    "Tailwind CSS",
    "TypeScript",
    "BasicApp",
    "XiHan"
  ],
  "author": {
    "name": "ZhaiFanhua",
    "email": "zhaifanhua@foxmail.com",
    "url": "https://www.zhaifanhua.com"
  },
  "license": "MIT",
  "homepage": "https://basicapp.xihanfun.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/XiHanFun/XiHan.BasicApp"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm -r install",
    "dev": "vite --mode development",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "cross-env CI=true oxlint && cross-env CI=true eslint .",
    "lint:fix": "cross-env CI=true oxlint --fix && cross-env CI=true eslint . --fix",
    "format": "prettier --write \"**/*.{json,css,html,md}\" --ignore-path .gitignore",
    "fix": "cross-env CI=true oxlint --fix && cross-env CI=true eslint . --fix && prettier --write \"**/*.{json,css,html,md}\" --ignore-path .gitignore",
    "postinstall": "simple-git-hooks",
    "clean": "rimraf dist",
    "clean:modules": "rimraf node_modules",
    "upgrade": "pnpm -r update",
    "build": "vue-tsc --noEmit && vite build --mode production",
    "build:dev": "vite build --mode development",
    "reinstall": "pnpm run clean:modules && pnpm install",
    "rebuild": "pnpm run clean && pnpm run build",
    "rebuild:dev": "pnpm run clean && pnpm run build:dev"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.40",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^25.9.5",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.5",
    "vue-tsc": "^3.3.7"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs}": [
      "oxlint --fix",
      "eslint --fix"
    ],
    "*.{json,css,html,md,yaml}": [
      "prettier --write"
    ]
  }
}
